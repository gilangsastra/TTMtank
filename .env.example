# Public site config (safe to expose, embedded in the bundle)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=6281327001001

# PostgreSQL — server-only.
# Recommended: Neon free tier (https://neon.tech). Use the pooled host.
DATABASE_URL=postgres://user:password@localhost:5432/ttm_tank

# Admin authentication — server-only.
#
# Generate the password hash:
#   npm run hash-password "your-strong-password"
# Copy the bcrypt output here:
ADMIN_PASSWORD_HASH=

# Generate the session secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 random bytes (hex):
SESSION_SECRET=
